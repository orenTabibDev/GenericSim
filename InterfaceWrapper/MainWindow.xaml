<Window x:Class="InterfaceWrapper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InterfaceWrapper"
        mc:Ignorable="d"
        Title="Interface Wrapper - C to C# Generator" Height="560" Width="920">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="150" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="LoadCFilesButton" Content="Load C files" Width="120" Height="30"
                    Click="LoadCFilesButton_Click" />
            <Button x:Name="GenerateButton" Content="Generate Wrapper" Width="150" Height="30" Margin="8,0,0,0"
                    IsEnabled="False" Click="GenerateButton_Click" />
            <Button x:Name="GenerateUiButton" Content="Generate UI" Width="130" Height="30" Margin="8,0,0,0"
                    IsEnabled="False" Click="GenerateUiButton_Click" />
            <Button x:Name="OpenOutputButton" Content="Open Output Folder" Width="150" Height="30" Margin="8,0,0,0"
                    IsEnabled="False" Click="OpenOutputButton_Click" />
        </StackPanel>

        <!-- Selected folder -->
        <TextBlock Grid.Row="1" Margin="0,0,0,8" TextWrapping="Wrap">
            <Run Text="Messages folder: " FontWeight="Bold" />
            <Run x:Name="FolderPathRun" Text="(none selected)" />
        </TextBlock>

        <!-- Discovered messages -->
        <DataGrid Grid.Row="2" x:Name="MessagesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Foreground" Value="Black" />
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Message" Binding="{Binding MessageName}" Width="2*" />
                <DataGridTextColumn Header="Msg Id" Binding="{Binding MessageIdDisplay}" Width="0.7*" />
                <DataGridTextColumn Header="Physical Type" Binding="{Binding PhysicalType}" Width="2*" />
                <DataGridTextColumn Header="Directions" Binding="{Binding Directions}" Width="1.5*" />
                <DataGridTextColumn Header="Global Variable" Binding="{Binding GlobalVariable}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Log header -->
        <TextBlock Grid.Row="3" Text="Log" FontWeight="Bold" Margin="0,8,0,4" />

        <!-- Log -->
        <TextBox Grid.Row="4" x:Name="LogTextBox" IsReadOnly="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12" />

        <!-- Status bar -->
        <StatusBar Grid.Row="5" Margin="0,8,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready." />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
